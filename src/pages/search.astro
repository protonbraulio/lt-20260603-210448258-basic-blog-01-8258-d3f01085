---
import "../styles/search.css";

import Container from "../components/layouts/Container.astro";
import PageTitle from "../components/ui/PageTitle.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import PagefindSearch from "astro-pagefind/components/Search";
---

<BaseLayout
    title="Search"
    description="Search articles and projects from Basic Blog Load Test 01 20260603-210448258."
    ogImage="https://lt-20260603-210448258-basic-blog-01-8258-d3f01085.pages.dev/images/og-default.svg"
>
    <Container class="py-12">
        <PageTitle title="Search" />

        <PagefindSearch
            id="search"
            className="pagefind-ui"
            uiOptions={{ showSubResults: true, autofocus: true }}
        />
    </Container>
</BaseLayout>
